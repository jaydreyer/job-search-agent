# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Claude API key for resume scoring (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Adzuna API credentials (free: https://developer.adzuna.com/)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Written automatically by `uv run jobsearch-agent-setup` — leave blank.
AGENT_ID=
ENVIRONMENT_ID=
